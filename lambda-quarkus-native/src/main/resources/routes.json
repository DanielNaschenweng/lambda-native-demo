[
  {
    "header_value": "order-created",
    "queue_name": "orders-queue-java-sample",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "required": ["order_id", "customer_name", "total"],
      "additionalProperties": false,
      "properties": {
        "order_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Z0-9-]+$"
        },
        "customer_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
]
